# ─── Local: Frontend (Vite) — copy to .env in this folder ───
VITE_API_URL=http://localhost:5000/api

# Production (Vercel): set VITE_API_URL in Project → Settings → Environment Variables
# Example: https://kanban-api.onrender.com/api  (your Render service URL + /api)

# ─── Local: Backend — copy to backend/.env ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/trello
PORT=5000
FRONTEND_URL=http://localhost:8080

# Production (Render env): DATABASE_URL = Neon connection string (use ?sslmode=require if needed)
# FRONTEND_URL = exact Vercel URL, e.g. https://your-app.vercel.app  (no trailing slash)
#
# Demo data on Neon: run backend/schema.sql once, then backend/seed_demo.sql in the SQL editor.
